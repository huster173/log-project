<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender (plain text, existing behaviour) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling JSON file appender — Filebeat reads this. LOG_FILE lets each
         horizontally-scaled replica write to its own file so they don't collide
         on the shared logs volume. -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${LOG_FILE:-app}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Roll over daily, keep 7 days -->
            <fileNamePattern>logs/${LOG_FILE:-app}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Add service name + replica identity to every JSON log line, so Kibana
                 can break down metrics (e.g. TPS) per replica instead of lumping all 3 together. -->
            <customFields>{"service":"log-backend","instance":"${LOG_FILE:-app}"}</customFields>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
    </root>

    <logger name="org.example.backend" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
    </logger>

    <logger name="org.springframework.boot.web.embedded" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
    </logger>

</configuration>